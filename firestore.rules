rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow any authenticated user to read any user document
      allow read: if request.auth != null;
      
      // Users can write to their own document (UID matches)
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Users can write to documents where their email matches any email field
      // This allows alumni email users to update their original @stanford.edu document
      allow write: if request.auth != null && 
        (resource.data.email == request.auth.token.email ||
         resource.data.emailAlumni == request.auth.token.email ||
         resource.data.emailAlumniGSB == request.auth.token.email);
      
      // Special case for admin
      allow write: if request.auth != null && 
        (request.auth.token.email == 'jpark22@stanford.edu' ||
         request.auth.token.email == 'jamespark@alumni.stanford.edu' ||
         request.auth.token.email == 'jamespark@alumni.gsb.stanford.edu')
        && (userId == request.auth.uid + '_gsb' || userId == request.auth.uid + '_undergrad');
      
      // Allow linking alumni emails to accounts with empty alumni email fields
      allow update: if request.auth != null
        && (request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && resource.data.emailAlumni == ''
        && resource.data.emailAlumniGSB == ''
        && validateAlumniLinking(resource.data, request.resource.data);
      
      // Validation for updates
      allow update: if request.auth != null 
        && (request.auth.uid == userId ||
            resource.data.email == request.auth.token.email ||
            resource.data.emailAlumni == request.auth.token.email ||
            resource.data.emailAlumniGSB == request.auth.token.email ||
            ((request.auth.token.email == 'jpark22@stanford.edu' ||
              request.auth.token.email == 'jamespark@alumni.stanford.edu' ||
              request.auth.token.email == 'jamespark@alumni.gsb.stanford.edu') && 
             (userId == request.auth.uid + '_gsb' || userId == request.auth.uid + '_undergrad')))
        && (request.auth.token.email.matches('.*@stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && validateUserUpdate(resource.data, request.resource.data);
      
      // Validation for creates
      allow create: if request.auth != null 
        && (request.auth.uid == userId || 
            ((request.auth.token.email == 'jpark22@stanford.edu' ||
              request.auth.token.email == 'jamespark@alumni.stanford.edu' ||
              request.auth.token.email == 'jamespark@alumni.gsb.stanford.edu') && 
             (userId == request.auth.uid + '_gsb' || userId == request.auth.uid + '_undergrad')))
        && (request.auth.token.email.matches('.*@stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && validateUserCreation(request.resource.data);
    }
    
    // Analytics collection
    match /analytics/{analyticsDoc} {
      allow read: if request.auth != null && 
        (request.auth.token.email == 'jpark22@stanford.edu' ||
         request.auth.token.email == 'jamespark@alumni.stanford.edu' ||
         request.auth.token.email == 'jamespark@alumni.gsb.stanford.edu');
      allow write: if false;
    }
    
    // Validation functions
    function validateAlumniLinking(existingData, newData) {
      // Only allow updating emailAlumni and emailAlumniGSB fields
      // All other fields must remain unchanged
      return existingData.uid == newData.uid
        && existingData.email == newData.email
        && existingData.name == newData.name
        && existingData.photoURL == newData.photoURL
        && existingData.crushes == newData.crushes
        && existingData.lockedCrushes == newData.lockedCrushes
        && existingData.matches == newData.matches
        && existingData.crushCount == newData.crushCount
        && existingData.userClass == newData.userClass
        && existingData.createdAt == newData.createdAt
        && newData.emailAlumni is string
        && newData.emailAlumniGSB is string
        && (newData.emailAlumni.matches('.*@alumni\\.stanford\\.edu$') ||
            newData.emailAlumniGSB.matches('.*@alumni\\.gsb\\.stanford\\.edu$'));
    }
    
    function validateUserUpdate(existingData, newData) {
      return existingData.uid == newData.uid
        && existingData.createdAt == newData.createdAt
        && newData.crushes is list
        && validateCrushes(newData.crushes)
        && validateLockedCrushes(existingData, newData);
    }
    
    function validateUserCreation(newData) {
      return newData.uid is string
        && (
          (newData.email is string && newData.email.matches('.*@stanford\\.edu$')) ||
          (newData.email is string && newData.email == '' && 
           (('emailAlumni' in newData && newData.emailAlumni is string && newData.emailAlumni.matches('.*@alumni\\.stanford\\.edu$')) ||
            ('emailAlumniGSB' in newData && newData.emailAlumniGSB is string && newData.emailAlumniGSB.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))))
        )
        && newData.crushes is list
        && newData.crushes.size() == 0
        && newData.matches is list
        && newData.matches.size() == 0
        && (!('lockedCrushes' in newData) || (newData.lockedCrushes is list && newData.lockedCrushes.size() == 0));
    }
    
    function validateCrushes(crushes) {
      return crushes.toSet().size() == crushes.size();
    }
    
    function validateLockedCrushes(existingData, newData) {
      return !('lockedCrushes' in existingData) || 
             !('lockedCrushes' in newData) ||
             (existingData.lockedCrushes is list && 
              newData.lockedCrushes is list &&
              existingData.lockedCrushes.toSet().difference(newData.crushes.toSet()).size() == 0);
    }
  }
}