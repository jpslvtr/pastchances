rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      let email = request.auth.token.email;
      return email == 'jpark22@stanford.edu' || 
             email == 'jamespark@alumni.stanford.edu' ||
             email == 'jamespark@alumni.gsb.stanford.edu';
    }
    
    // Helper to check if this is the user's document (including admin suffix)
    function isUserDocument(userId) {
      return request.auth.uid == userId ||
             (isAdmin() && (userId == request.auth.uid + '_gsb' || userId == request.auth.uid + '_undergrad'));
    }
    
    // Validation functions
    function validateAlumniLinking(existingData, newData) {
      // Only allow updating emailAlumni and emailAlumniGSB fields
      // All other fields must remain unchanged
      return existingData.uid == newData.uid
        && existingData.email == newData.email
        && existingData.name == newData.name
        && existingData.photoURL == newData.photoURL
        && existingData.crushes == newData.crushes
        && existingData.lockedCrushes == newData.lockedCrushes
        && existingData.matches == newData.matches
        && existingData.crushCount == newData.crushCount
        && existingData.userClass == newData.userClass
        && existingData.createdAt == newData.createdAt
        && newData.emailAlumni is string
        && newData.emailAlumniGSB is string
        && (newData.emailAlumni.matches('.*@alumni\\.stanford\\.edu$') ||
            newData.emailAlumniGSB.matches('.*@alumni\\.gsb\\.stanford\\.edu$'));
    }
    
    // Admin unlinking validation - allows clearing emailAlumni/emailAlumniGSB
    function validateAdminUnlinkingAlumni(existingData, newData) {
      // All fields except emailAlumni and emailAlumniGSB must remain unchanged
      return existingData.uid == newData.uid
        && existingData.email == newData.email
        && existingData.name == newData.name
        && existingData.photoURL == newData.photoURL
        && existingData.crushes == newData.crushes
        && existingData.lockedCrushes == newData.lockedCrushes
        && existingData.matches == newData.matches
        && existingData.crushCount == newData.crushCount
        && existingData.userClass == newData.userClass
        && existingData.createdAt == newData.createdAt
        && newData.emailAlumni is string
        && newData.emailAlumniGSB is string
        && newData.emailAlumni == ''
        && newData.emailAlumniGSB == '';
    }
    
    // Admin unlinking validation - allows clearing uid and email for TC2 case
    function validateAdminUnlinkingClaim(existingData, newData) {
      // All fields except uid and email must remain unchanged
      return existingData.name == newData.name
        && existingData.photoURL == newData.photoURL
        && existingData.crushes == newData.crushes
        && existingData.lockedCrushes == newData.lockedCrushes
        && existingData.matches == newData.matches
        && existingData.crushCount == newData.crushCount
        && existingData.userClass == newData.userClass
        && existingData.createdAt == newData.createdAt
        && newData.uid is string
        && newData.uid == ''
        && newData.email is string
        && newData.email == '';
    }
    
    // Validate that protected fields haven't changed (for regular updates)
    // If a field is not in the update, we don't check it
    function validateProtectedFieldsUnchanged(existingData, newData) {
      return (!('uid' in newData) || existingData.uid == newData.uid)
        && (!('email' in newData) || existingData.email == newData.email)
        && (!('name' in newData) || existingData.name == newData.name)
        && (!('photoURL' in newData) || existingData.photoURL == newData.photoURL)
        && (!('userClass' in newData) || existingData.userClass == newData.userClass)
        && (!('createdAt' in newData) || existingData.createdAt == newData.createdAt)
        && (!('emailAlumni' in newData) || !('emailAlumni' in existingData) || existingData.emailAlumni == newData.emailAlumni)
        && (!('emailAlumniGSB' in newData) || !('emailAlumniGSB' in existingData) || existingData.emailAlumniGSB == newData.emailAlumniGSB);
    }
    
    function validateUserUpdate(existingData, newData) {
      return validateProtectedFieldsUnchanged(existingData, newData)
        && newData.crushes is list
        && validateCrushes(newData.crushes)
        && validateLockedCrushes(existingData, newData);
    }
    
    function validateUserCreation(newData) {
      return newData.uid is string
        && (
          (newData.email is string && newData.email.matches('.*@stanford\\.edu$')) ||
          (newData.email is string && newData.email == '' && 
           (('emailAlumni' in newData && newData.emailAlumni is string && newData.emailAlumni.matches('.*@alumni\\.stanford\\.edu$')) ||
            ('emailAlumniGSB' in newData && newData.emailAlumniGSB is string && newData.emailAlumniGSB.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))))
        )
        && newData.crushes is list
        && newData.crushes.size() == 0
        && newData.matches is list
        && newData.matches.size() == 0
        && (!('lockedCrushes' in newData) || (newData.lockedCrushes is list && newData.lockedCrushes.size() == 0));
    }
    
    function validateCrushes(crushes) {
      return crushes.toSet().size() == crushes.size();
    }
    
    function validateLockedCrushes(existingData, newData) {
      return !('lockedCrushes' in existingData) || 
             !('lockedCrushes' in newData) ||
             (existingData.lockedCrushes is list && 
              newData.lockedCrushes is list &&
              existingData.lockedCrushes.toSet().difference(newData.crushes.toSet()).size() == 0);
    }
    
    // Users collection
    match /users/{userId} {
      // Allow any authenticated user to read any user document
      allow read: if request.auth != null;
      
      // Allow users to create their own document
      allow create: if request.auth != null 
        && isUserDocument(userId)
        && (request.auth.token.email.matches('.*@stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && validateUserCreation(request.resource.data);
      
      // ADMIN UNLINKING - Allow admin to clear alumni emails (TC4/5)
      allow update: if request.auth != null
        && isAdmin()
        && validateAdminUnlinkingAlumni(resource.data, request.resource.data);
      
      // ADMIN UNLINKING - Allow admin to clear uid and email (TC2)
      allow update: if request.auth != null
        && isAdmin()
        && validateAdminUnlinkingClaim(resource.data, request.resource.data);
      
      // Allow linking alumni emails to accounts with empty alumni email fields
      // IMPORTANT: This prevents hijacking by requiring emails to be empty before linking
      allow update: if request.auth != null
        && (request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && resource.data.emailAlumni == ''
        && resource.data.emailAlumniGSB == ''
        && validateAlumniLinking(resource.data, request.resource.data);
      
      // Allow users to update documents where their email matches any email field
      // This allows alumni email users to update their original @stanford.edu document
      allow update: if request.auth != null 
        && (isUserDocument(userId) ||
            resource.data.email == request.auth.token.email ||
            resource.data.emailAlumni == request.auth.token.email ||
            resource.data.emailAlumniGSB == request.auth.token.email)
        && (request.auth.token.email.matches('.*@stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
            request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'))
        && validateUserUpdate(resource.data, request.resource.data);
    }
    
    // Class list collection
    match /classList/{classId} {
      allow read: if request.auth != null && 
        (request.auth.token.email.matches('.*@stanford\\.edu$') ||
         request.auth.token.email.matches('.*@alumni\\.stanford\\.edu$') ||
         request.auth.token.email.matches('.*@alumni\\.gsb\\.stanford\\.edu$'));
      allow write: if false;
    }
    
    // Analytics collection
    match /analytics/{analyticsDoc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    // Account Linking Audit collection
    match /accountLinkingAudit/{auditId} {
      allow read: if isAdmin();
      allow create: if false; // Only created through transactions in code
      allow update: if isAdmin(); // Allow admin to mark as unlinked
      allow delete: if false; // Never delete audit records
    }
  }
}